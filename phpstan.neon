includes:
    - phpstan-baseline.neon
    - vendor/dev-tools/phpstan/phpstan-symfony/extension.neon
    - vendor/dev-tools/phpstan/phpstan-doctrine/extension.neon

parameters:
    level: 5
    bootstrapFiles:
        - phpstan-bootstrap.php
    paths:
        - src
        - tests
    scanFiles:
        - base/fs_maintenance_mode.php
        - base/install_security.php
        - controller/force_password_change.php
        - plugins/OidcProvider/controller/admin_oidc_diagnostics.php
    ignoreErrors:
        # False positives: PHPStan infers constant values from test bootstrap,
        # but these checks are needed at runtime when constants may vary
        -
            identifier: booleanNot.alwaysTrue
            path: src/Core/Base/Controller.php
        -
            identifier: if.alwaysTrue
            path: src/Core/Base/Controller.php