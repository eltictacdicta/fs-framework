# =============================================================================
# FSFramework .gitignore
# =============================================================================

# IDE and editor files
/.idea/
/.vscode/
/nbproject/
*.swp
*.swo
*~
.DS_Store
.htaccess
# Documentation (generated)
/doc/

# Dependencies (installed via composer/npm)
/node_modules/
/vendor/

# Temporary and cache files
/tmp/*
!/tmp/index.php
/MyFiles/

# Configuration (contains credentials)
config.php
config.php.bak*
package-lock.json

# =============================================================================
# PLUGINS (exclude all except core)
# =============================================================================
/plugins/*
!/plugins/adminlte/
!/plugins/AdminLTE/
!/plugins/business_data/
!/plugins/catalogo_core/
!/plugins/catalogo_core/**
!/plugins/legacy_support/
!/plugins/facturascripts_support/
!/plugins/portal/
!/plugins/hola_mundo/
!/plugins/clientes_core/
!/plugins/clientes_catalogo/
!/plugins/clientes_facturacion

# =============================================================================
# USER UPLOADS AND GENERATED CONTENT
# =============================================================================
/imgs/
/images/
logs/api_security.log

# =============================================================================
# DDEV LOCAL ENVIRONMENT
# =============================================================================
.ddev/

# Legacy AdminLTE download
AdminLTE-2.4.18

# =============================================================================
# BACKUPS (protect directory, exclude contents)
# =============================================================================
/backups/*
!/backups/index.php

# Update and Backup data (legacy)
/update-and-backup/data/*
!/update-and-backup/data/.htaccess
!/update-and-backup/data/index.php

# =============================================================================
# TESTING
# =============================================================================
.phpunit.cache/
.phpunit.result.cache
coverage/

# =============================================================================
# SECURITY: SENSITIVE FILES (NEVER COMMIT)
# =============================================================================
# Logs may contain sensitive data
*.log

# Database exports and backups
*.sql
*.sql.gz
*.bak
*.backup
*.dump
*.sqlite
*.db

# Environment and secrets
.env
.env.local
.env.*.local
.fs_secret_key

# Emergency scripts (upload manually, delete after use)
emergency_admin_reset.php
reset_admin_password.php

# Composer auth tokens
auth.json

# SSH keys accidentally placed in project
*.pem
*.key
id_rsa*
id_ed25519*

# =============================================================================
# SECURITY: HTACCESS
# =============================================================================
# Rules are centralized in /.htaccess (root). Optional: apk/, imgs/ for MIME/cache.
