## Security Component — Password Hasher

```php
use FSFramework\DependencyInjection\Container;

// ✅ SIEMPRE usar el hasher del contenedor
$hasher = Container::passwordHasher();

// Hash de nueva contraseña
$hash = $hasher->hash($plainPassword);

// Verificar contraseña en login
if (!$hasher->verify($storedHash, $inputPassword)) {
    $this->miniLog->alert('Contraseña incorrecta');
    return false;
}

// Verificar si necesita rehash (cuando cambia el algoritmo)
if ($hasher->needsRehash($storedHash)) {
    $newHash = $hasher->hash($plainPassword);
    $user->updatePassword($newHash);
}
```

## Estructura de un Controlador Moderno

```php
<?php

declare(strict_types=1);

use FSFramework\Attribute\FSRoute;
use FSFramework\DependencyInjection\Container;
use FSFramework\Event\FSEventDispatcher;
use FSFramework\Security\CSRFProtection;
use Symfony\Component\HttpFoundation\JsonResponse;

#[FSRoute('/api/v1/productos', methods: ['GET', 'POST'])]
class api_productos extends fs_controller
{
    protected function private_core(): void
    {
        $method = $this->request->getMethod();

        match($method) {
            'GET'  => $this->handleGet(),
            'POST' => $this->handlePost(),
            default => $this->notFound(),
        };
    }

    private function handleGet(): void
    {
        $cache = Container::cache();
        $productos = $cache->get('productos_lista', fn() =>
            $this->db->select("SELECT * FROM fs_productos WHERE activo = 1")
        );

        (new JsonResponse(['data' => $productos, 'success' => true]))->send();
        exit;
    }

    private function handlePost(): void
    {
        // 1. Validar CSRF
        if (!CSRFProtection::validate($this->request->get('_token'))) {
            (new JsonResponse(['error' => 'Token inválido'], 403))->send();
            exit;
        }

        // 2. Validar y sanitizar input
        $nombre = filter_var(
            $this->request->request->getString('nombre'),
            FILTER_SANITIZE_SPECIAL_CHARS
        );

        if (empty($nombre)) {
            (new JsonResponse(['error' => 'Nombre requerido'], 422))->send();
            exit;
        }

        // 3. Lógica de negocio
        $producto = new producto();
        $producto->nombre = $nombre;

        if (!$producto->save()) {
            (new JsonResponse(['error' => 'Error al guardar'], 500))->send();
            exit;
        }

        // 4. Limpiar caché
        Container::cache()->invalidateTags(['productos']);

        (new JsonResponse(['data' => $producto, 'success' => true], 201))->send();
        exit;
    }
}
```
