{{ include('header.html.twig') }}

<div class="container-fluid" style="margin-top: 10px;">
    <div class="row">
        <div class="col-xs-6">
            <div class="btn-group">
                <a class="btn btn-sm btn-default" href="{{ fsc.url()|raw }}" title="{{ 'reload'|trans }}">
                    <span class="glyphicon glyphicon-refresh"></span>
                </a>
            </div>
        </div>
        <div class="col-xs-6 text-right">
            <h2 style="margin-top: 0px;">
                <i class="fa fa-envelope"></i>&nbsp;
                {{ 'email-config'|trans }}
            </h2>
        </div>
    </div>
</div>

<div class="container-fluid" style="margin-top: 20px;">
    <form method="post" action="{{ fsc.url()|raw }}">
        {{ csrf_field() }}
        <input type="hidden" name="action" value="save"/>

        <div class="panel panel-primary">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-cog"></i>&nbsp;
                    {{ 'email-smtp-config'|trans }}
                </h3>
            </div>
            <div class="panel-body">
                <p class="help-block">
                    {{ 'email-config-description'|trans }}
                </p>

                <div class="row">
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label for="mail_mailer">{{ 'email-mailer'|trans }}</label>
                            <select name="mail_mailer" id="mail_mailer" class="form-control">
                                {% for key, value in fsc.mailers() %}
                                <option value="{{ key }}" {% if key == fsc.emailConfig['mail_mailer'] %}selected{% endif %}>
                                    {{ value }}
                                </option>
                                {% endfor %}
                            </select>
                            <p class="help-block small">{{ 'email-mailer-help'|trans }}</p>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label for="mail_from_email">{{ 'email-from-email'|trans }}</label>
                            <div class="input-group">
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-envelope"></span>
                                </span>
                                <input type="email" class="form-control" id="mail_from_email" name="mail_from_email" 
                                       value="{{ fsc.emailConfig['mail_from_email'] }}" 
                                       placeholder="no-reply@tudominio.com"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label for="mail_from_name">{{ 'email-from-name'|trans }}</label>
                            <div class="input-group">
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-user"></span>
                                </span>
                                <input type="text" class="form-control" id="mail_from_name" name="mail_from_name" 
                                       value="{{ fsc.emailConfig['mail_from_name'] }}" 
                                       placeholder="Mi Empresa"/>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="panel panel-warning" id="smtp_config">
            <div class="panel-heading">
                <h3 class="panel-title">
                    <i class="fa fa-server"></i>&nbsp;
                    {{ 'email-smtp-server'|trans }}
                </h3>
            </div>
            <div class="panel-body">
                <p class="help-block">
                    {{ 'email-smtp-config-help'|trans }}
                </p>

                <div class="row">
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label for="mail_host">{{ 'email-host'|trans }}</label>
                            <div class="input-group">
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-globe"></span>
                                </span>
                                <input type="text" class="form-control" id="mail_host" name="mail_host" 
                                       value="{{ fsc.emailConfig['mail_host'] }}" 
                                       placeholder="smtp.gmail.com" autocomplete="off"/>
                            </div>
                        </div>
                    </div>
                    <div class="col-sm-2">
                        <div class="form-group">
                            <label for="mail_port">{{ 'email-port'|trans }}</label>
                            <input type="number" class="form-control" id="mail_port" name="mail_port" 
                                   value="{{ fsc.emailConfig['mail_port'] }}" 
                                   placeholder="587" min="1" max="65535"/>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label for="mail_enc">{{ 'email-encryption'|trans }}</label>
                            <select name="mail_enc" id="mail_enc" class="form-control">
                                {% for key, value in fsc.encriptaciones() %}
                                <option value="{{ key }}" {% if key == fsc.emailConfig['mail_enc'] %}selected{% endif %}>
                                    {{ value }}
                                </option>
                                {% endfor %}
                            </select>
                        </div>
                    </div>
                    <div class="col-sm-3">
                        <div class="form-group">
                            <label for="mail_user">{{ 'email-user'|trans }}</label>
                            <div class="input-group">
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-user"></span>
                                </span>
                                <input type="text" class="form-control" id="mail_user" name="mail_user" 
                                       value="{{ fsc.emailConfig['mail_user'] }}" 
                                       placeholder="usuario@gmail.com" autocomplete="off"/>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row">
                    <div class="col-sm-4">
                        <div class="form-group">
                            <label for="mail_password">{{ 'email-password'|trans }}</label>
                            <div class="input-group">
                                <span class="input-group-addon">
                                    <span class="glyphicon glyphicon-lock"></span>
                                </span>
                                <input type="password" class="form-control" id="mail_password" name="mail_password" 
                                       placeholder="{% if fsc.emailConfig['mail_password'] %}••••••••{% else %}{{ 'email-password-placeholder'|trans }}{% endif %}" 
                                       autocomplete="new-password"/>
                            </div>
                            <p class="help-block small">{{ 'email-password-help'|trans }}</p>
                        </div>
                    </div>
                    <div class="col-sm-8">
                        <div class="form-group">
                            <label>&nbsp;</label>
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" name="mail_low_security" value="1" 
                                           {% if fsc.emailConfig['mail_low_security'] %}checked{% endif %}/>
                                    {{ 'email-low-security'|trans }}
                                </label>
                            </div>
                            <p class="help-block small">{{ 'email-low-security-help'|trans }}</p>
                        </div>
                    </div>
                </div>
            </div>
            <div class="panel-footer">
                <p class="help-block small">
                    <i class="fa fa-lightbulb-o"></i>&nbsp;
                    {{ 'email-gmail-tip'|trans|raw }}
                </p>
            </div>
        </div>

        <div class="row">
            <div class="col-sm-12">
                <div class="btn-group">
                    <button type="submit" class="btn btn-primary">
                        <span class="glyphicon glyphicon-floppy-disk"></span>&nbsp;
                        {{ 'save'|trans }}
                    </button>
                    <button type="submit" class="btn btn-info" name="test_after_save" value="1">
                        <span class="glyphicon glyphicon-flash"></span>&nbsp;
                        {{ 'email-save-and-test'|trans }}
                    </button>
                </div>
                <button type="button" class="btn btn-default" onclick="testConnection();">
                    <span class="glyphicon glyphicon-ok-circle"></span>&nbsp;
                    {{ 'email-test-connection'|trans }}
                </button>
            </div>
        </div>
    </form>

    {% if fsc.canSendMail() %}
    <div class="alert alert-success" style="margin-top: 20px;">
        <i class="fa fa-check-circle"></i>&nbsp;
        {{ 'email-config-ready'|trans }}
    </div>
    {% else %}
    <div class="alert alert-warning" style="margin-top: 20px;">
        <i class="fa fa-exclamation-triangle"></i>&nbsp;
        {{ 'email-config-incomplete'|trans }}
    </div>
    {% endif %}
</div>

<script>
function testConnection() {
    var form = document.querySelector('form');
    var actionInput = form.querySelector('input[name="action"]');
    actionInput.value = 'test';
    form.submit();
}

$(document).ready(function() {
    var mailerSelect = $('#mail_mailer');
    var smtpConfig = $('#smtp_config');

    function toggleSmtpConfig() {
        if (mailerSelect.val() === 'smtp') {
            smtpConfig.show();
        } else {
            smtpConfig.hide();
        }
    }

    mailerSelect.on('change', toggleSmtpConfig);
    toggleSmtpConfig();
});
</script>

{{ include('footer.html.twig') }}
